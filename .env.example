# Nexus environment — copy to ~/AI_Agent/.env and fill in.
# The real .env is gitignored; do NOT commit secrets.

# GitHub personal access token (fine-grained PAT recommended).
# Used by tools/github_tool.py and the github MCP server in mcp/servers.json.
GITHUB_TOKEN=

# Z.AI / GLM API key — reserved for the GLM-5.1 code-tier route in Phase 6.
Z_AI_API_KEY=

# Brave Search API — reserved for Phase 6 web-search tool.
BRAVE_SEARCH_API_KEY=

# Tailscale API key — reserved for remote-device / fleet integration.
TAILSCALE_API_KEY=

# Sparky TTS voice. Male Kokoro voices (preferred): am_adam, am_michael,
# bm_george, bm_lewis. Female: af_sky, af_nova, bf_emma, af_heart.
# Leave empty to auto-probe (default order puts am_adam first).
# Set an "en-US-*Neural" name to route through edge-tts instead
# (e.g. en-US-GuyNeural / en-US-DavisNeural for male,
# en-US-JennyNeural / en-US-AriaNeural for female).
SPARKY_VOICE=am_adam

# Telegram Bot — for notifications and remote commands.
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ERNIE Image Generation API
ERNIE_API_KEY=

# Vercel deployment token
VERCEL_TOKEN=
