# Nexus secrets — copy to ~/AI_Agent/config/secrets.yaml and fill in.
# The real secrets.yaml is gitignored; do NOT commit real values.
#
# Helper: core/secrets.py reads this file. Format is "KEY: value" or
# "KEY=value"; quotes optional. Both `:` and `=` separators work.

# GitHub fine-grained PAT for github_tool.py + the github MCP server.
# Scopes needed: repo (read+write), pull_requests, issues.
GITHUB_PAT: "your_github_personal_access_token"
GITHUB_TOKEN: "your_github_personal_access_token"

# Telegram bot — see ~/AI_Agent/docs/telegram-setup.md for @BotFather flow.
TELEGRAM_BOT_TOKEN: "your_telegram_bot_token"
TELEGRAM_CHAT_ID: "your_telegram_chat_id"

# Anthropic API — used by Phase 22 cc_dispatcher when claude CLI auths via
# this key instead of the local browser session.
ANTHROPIC_API_KEY: "your_anthropic_api_key"

# Z.ai / GLM — Phase 14.6 escalation tier.
Z_AI_API_KEY: "optional_zai_glm_api_key"

# Search backends — fall back through searxng (free, local) when missing.
BRAVE_SEARCH_API_KEY: "optional_brave_search_api_key"
TAVILY_API_KEY: "optional_tavily_api_key"

# Vercel — Phase 7.4 deploy tool.
VERCEL_TOKEN: "optional_vercel_token"

# ERNIE / Baidu image generation — Phase 7.2.
ERNIE_API_KEY: "optional_ernie_api_key"

# DeepSeek — alternative coding model route.
DEEPSEEK_API_KEY: "optional_deepseek_api_key"

# Higgsfield — Phase 21 video generation.
HIGGSFIELD_API_KEY: "optional_higgsfield_api_key"

# Supabase — BidWatt + ReserveStack backends.
SUPABASE_URL: "optional_supabase_project_url"
SUPABASE_ANON_KEY: "optional_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY: "optional_supabase_service_role_key"

# Tailscale — fleet integration (reserved).
TAILSCALE_API_KEY: "optional_tailscale_api_key"

# Monthly Claude Code dispatch budget (USD). Defaults to 50 in code.
CLAUDE_CODE_MONTHLY_BUDGET: "50"
